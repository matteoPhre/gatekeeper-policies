{
  "name": "@matteophre/gatekeeper-policies",
  "version": "1.2.1",
  "description": "An enterprise-grade, database-agnostic password policy engine for Node.js",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/matteoPhre/gatekeeper-policies.git"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node --input-type=module -e \"import fs from 'node:fs'; fs.rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.ts'",
    "security:audit:prod": "npm audit --omit=dev",
    "security:audit:dev": "npm audit",
    "security:pack": "npm pack --dry-run",
    "release:check": "npm run build && npm test && npm run security:audit:prod && npm run security:pack",
    "publish:npm:dry": "npm publish --dry-run --access public",
    "publish:npm": "npm publish --access public --provenance",
    "prepublishOnly": "npm run release:check"
  },
  "keywords": [
    "password",
    "policy",
    "identity",
    "rotation",
    "expiry",
    "security",
    "agnostic"
  ],
  "author": "",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.3",
    "express": "^5.1.0",
    "fastify": "^5.0.0",
    "supertest": "^7.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
